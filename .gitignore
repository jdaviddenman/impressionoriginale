# Fingerprint raw HTML captures — bulky and regenerable; keep SUMMARY.txt + detail/ only.
reports/*/raw/

# Playwright MCP auth state — session cookies, never commit.
wp-auth.json
.playwright-mcp/

# Process core dumps — crash artifacts, huge, never commit.
core
core.*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc
.venv/

# Node
node_modules/

# Logs
*.log

# Environment
.env
.env.*
